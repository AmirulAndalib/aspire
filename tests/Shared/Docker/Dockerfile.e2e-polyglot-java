# Polyglot Dockerfile for Java AppHost E2E tests.
# Extends the shared polyglot base with the JDK required by Java AppHosts.

FROM aspire-e2e-polyglot-base

RUN /usr/local/bin/apt-retry sh -c 'apt-get update -qq && apt-get install -y --no-install-recommends openjdk-25-jdk' && \
    rm -rf /var/lib/apt/lists/*
