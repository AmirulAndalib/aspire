@using Aspire.Dashboard.Model
@using Aspire.Dashboard.Resources

@if (NotificationService.UnreadCount > 0)
{
    <FluentButton Class="header-button"
                  Appearance="Appearance.Stealth" OnClick="@OnClick"
                  Title="@Loc[nameof(Layout.MainLayoutLaunchNotifications)]" aria-label="@Loc[nameof(Layout.MainLayoutLaunchNotifications)]">
        <FluentCounterBadge Count="@NotificationService.UnreadCount"
                            Max="9"
                            ShowOverflow="true"
                            BackgroundColor="@Color.FillInverse"
                            Color="Color.Fill"
                            Appearance="Appearance.Accent">
            <ChildContent>
                <FluentIcon Value="@(new Icons.Regular.Size24.Alert())" Color="Color.Neutral" Style="vertical-align: sub;" />
            </ChildContent>
        </FluentCounterBadge>
    </FluentButton>
}
else
{
    <FluentButton Class="header-button"
                  Appearance="Appearance.Stealth" OnClick="@OnClick"
                  Title="@Loc[nameof(Layout.MainLayoutLaunchNotifications)]" aria-label="@Loc[nameof(Layout.MainLayoutLaunchNotifications)]">
        <FluentIcon Value="@(new Icons.Regular.Size24.Alert())" Color="Color.Neutral" />
    </FluentButton>
}
